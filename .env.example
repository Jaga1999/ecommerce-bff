# Application
NODE_ENV=development
APP_PORT=8080
BFF_CONTEXT_PATH=/api
FRONTEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3000/dashboard

# Database
APP_DB_HOST=localhost
APP_DB_PORT=5433
APP_DB_NAME=bff_app
APP_DB_USER=bff
APP_DB_PASSWORD=change_me
DB_MIGRATIONS_RUN=true

# Keycloak
APP_KEYCLOAK_SERVER_URL=http://localhost:8080
KC_EXTERNAL_URL=http://localhost:8081
KC_PORT=8081
KC_REALM=ecommerce-realm
KC_CLIENT_ID=ecommerce-bff
KC_CLIENT_SECRET=your_client_secret
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_ADMIN_CLIENT_ID=admin-cli

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Session
SESSION_ID_HEADER=X-Session-ID
SESSION_COOKIE_NAME=SESSION_ID

# Google OAuth (Managed via Keycloak, but credentials stored here for reference/sync)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
